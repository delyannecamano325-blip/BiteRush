<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>BiteRush</title>

<style>
body {
    font-family: Arial, sans-serif;
    margin: 0;
    background-color: #111;
    color: white;
}

/* HEADER CENTRADO */
header {
    background: linear-gradient(90deg, #ff3c00, #ffcc00);
    text-align: center;
    padding: 20px;
}

header img {
    width: 150px;
}

h1 {
    margin: 10px 0;
    font-size: 40px; /* nombre más grande */
    font-weight: bold;
}

header p {
    margin: 0;
}

/* SECCIONES */
section {
    padding: 30px;
}

/* TITULOS */
h2 {
    color: #ffcc00;
    text-align: center;
    margin-bottom: 20px;
}

/* MENU */
.menu {
    max-width: 600px;
    margin: auto;
}

.menu-item {
    display: flex;
    justify-content: space-between;
    border-bottom: 1px dashed #555;
    padding: 10px 0;
    font-size: 18px;
}

.menu-item span {
    color: #ffcc00;
    font-weight: bold;
}

/* BOTON */
button {
    background-color: #ff3c00;
    border: none;
    padding: 12px 20px;
    color: white;
    font-weight: bold;
    cursor: pointer;
    border-radius: 5px;
}

/* FOOTER */
footer {
    background-color: #000;
    text-align: center;
    padding: 15px;
}
</style>

</head>

<body>

<header>
    <img src="logo.png" alt="Logo">
    <h1>¡Bienvenido a nuestro menú digital!</h1>
</header>

<!-- HAMBURGUESAS -->
<section>
    <h2>Hamburguesas</h2>
    <div class="menu">
        <div class="menu-item">Hamburguesa clásica <span>$3.50</span></div>
        <div class="menu-item">Hamburguesa personalizada <span>$5.50</span></div>
    </div>
</section>

<!-- HOT DOG -->
<section>
    <h2>Hot dogs</h2>
    <div class="menu">
        <div class="menu-item">Hot dog clásico <span>$3.50</span></div>
        <div class="menu-item">Hot dog personalizado <span>$4.50</span></div>
    </div>
</section>

<!-- WRAPS -->
<section>
    <h2>Wraps</h2>
    <div class="menu">
        <div class="menu-item">Wrap de pollo <span>$3.50</span></div>
        <div class="menu-item">Wrap de carne <span>$3.50</span></div>
        <div class="menu-item">Wrap mixto <span>$4.50</span></div>
    </div>
</section>

<!-- SALCHIPAPAS -->
<section>
    <h2>Salchipapas</h2>
    <div class="menu">
        <div class="menu-item">Salchipapa clásica <span>$3.00</span></div>
        <div class="menu-item">Salchipapa extrema <span>$5.75</span></div>
    </div>
</section>

<!-- BEBIDAS -->
<section>
    <h2>Bebidas</h2>
    <div class="menu">
        <div class="menu-item">Refrescos <span>$1.25</span></div>
        <div class="menu-item">Batidos naturales <span>$3.00</span></div>
    </div>
</section>

<!-- PEDIDOS -->
<section style="text-align:center;">
    <h2>Haz tu pedido</h2>
    <p>Pide por WhatsApp y recoge sin filas o recibe en casa</p>
    <button onclick="window.location.href='https://wa.me/50700000000'">
        Pedir ahora
    </button>
</section>

<footer>
    <p>© 2026 BiteRush - Fast Food • Flavor • Speed</p>
</footer>

</body>
</html>
